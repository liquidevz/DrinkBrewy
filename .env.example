# Shopify Configuration (Legacy - not used with backend)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_REVALIDATION_SECRET="your-revalidation-secret"

# Backend Configuration
BACKEND_URL=http://localhost:3000

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shiprocket Checkout Configuration
# Get these from Shiprocket Checkout dashboard after registration
# Sign up at: https://checkout.shiprocket.in/
SHIPROCKET_CHECKOUT_API_KEY=your_api_key_here
SHIPROCKET_CHECKOUT_SECRET_KEY=your_secret_key_here

# Shiprocket API Configuration (for shipping)
# Get these from Shiprocket dashboard: https://app.shiprocket.in
SHIPROCKET_EMAIL="your-shiprocket-email"
SHIPROCKET_PASSWORD="your-shiprocket-password"

# Razorpay Configuration (Optional - only if using Razorpay instead of Shiprocket Checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
